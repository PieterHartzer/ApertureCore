# App runtime
NUXT_HOST=0.0.0.0
NUXT_PORT=3300
NUXT_PUBLIC_APP_URL=http://localhost:3300

# App persistence database
APP_DATABASE_URL=postgres://user:password@host:5432/database
APP_DATABASE_ENCRYPTION_KEY=change-me-to-a-long-random-secret

# OIDC provider
NUXT_OIDC_PROVIDERS_OIDC_CLIENT_ID=replace-with-your-client-id
NUXT_OIDC_PROVIDERS_OIDC_CLIENT_SECRET=replace-with-your-client-secret
NUXT_OIDC_PROVIDERS_OIDC_AUTHORIZATION_URL=https://your-provider.example.com/oauth/v2/authorize
NUXT_OIDC_PROVIDERS_OIDC_TOKEN_URL=https://your-provider.example.com/oauth/v2/token
NUXT_OIDC_PROVIDERS_OIDC_USER_INFO_URL=https://your-provider.example.com/oidc/v1/userinfo
NUXT_OIDC_PROVIDERS_OIDC_LOGOUT_URL=https://your-provider.example.com/oidc/v1/end_session
NUXT_OIDC_PROVIDERS_OIDC_OPENID_CONFIGURATION=https://your-provider.example.com/.well-known/openid-configuration
NUXT_OIDC_PROVIDERS_OIDC_ISSUER=https://your-provider.example.com
NUXT_OIDC_PROVIDERS_OIDC_JWKS_URI=https://your-provider.example.com/oauth/v2/keys
NUXT_OIDC_PROVIDERS_OIDC_REDIRECT_URI=http://localhost:3300/auth/oidc/callback
# Replace with the scopes your provider requires.
APP_OIDC_SCOPE=openid profile email offline_access

# OIDC organisation claim mapping
APP_OIDC_ORGANIZATION_ID_CLAIM=replace-with-your-organization-id-claim
APP_OIDC_ORGANIZATION_NAME_CLAIM=replace-with-your-organization-name-claim
APP_OIDC_ORGANIZATION_PRIMARY_DOMAIN_CLAIM=replace-with-your-organization-primary-domain-claim

# Session and token secrets
NUXT_OIDC_AUTH_SESSION_SECRET=replace-with-a-long-random-string
NUXT_OIDC_SESSION_SECRET=replace-with-a-long-random-string
NUXT_OIDC_TOKEN_KEY=data:;base64,replace-with-a-base64-key
