{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Nuxt: local dev server",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "program": "${workspaceFolder}/node_modules/nuxt/bin/nuxt.mjs",
      "args": [
        "dev",
        "--dotenv",
        ".env.development"
      ],
      "env": {
        "NUXT_HOST": "0.0.0.0",
        "NUXT_PORT": "3002",
        "NUXT_PUBLIC_APP_URL": "http://localhost:3300"
      },
      "console": "integratedTerminal",
      "outputCapture": "std",
      "autoAttachChildProcesses": true,
      "skipFiles": [
        "<node_internals>/**"
      ]
    },
    {
      "name": "Nuxt: browser via proxy",
      "type": "chrome",
      "request": "launch",
      "preLaunchTask": "Dev Stack: ensure proxy",
      "url": "http://localhost:3300",
      "webRoot": "${workspaceFolder}"
    },
    {
      "name": "Nuxt: full stack via proxy",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "program": "${workspaceFolder}/node_modules/nuxt/bin/nuxt.mjs",
      "args": [
        "dev",
        "--dotenv",
        ".env.development"
      ],
      "env": {
        "NUXT_HOST": "0.0.0.0",
        "NUXT_PORT": "3002",
        "NUXT_PUBLIC_APP_URL": "http://localhost:3300"
      },
      "preLaunchTask": "Dev Stack: ensure proxy",
      "console": "integratedTerminal",
      "outputCapture": "std",
      "autoAttachChildProcesses": true,
      "skipFiles": [
        "<node_internals>/**"
      ],
      "serverReadyAction": {
        "pattern": "Local:\\s+(https?://\\S+)",
        "uriFormat": "http://localhost:3300",
        "action": "debugWithChrome"
      }
    }
  ]
}
